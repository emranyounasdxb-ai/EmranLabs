NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only OpenAI Responses API configuration for EM AI.
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.1-mini
AI_RATE_LIMIT_MAX=12
AI_RATE_LIMIT_WINDOW_MS=600000

# Server-only SMTP configuration for the secure Contact application.
CONTACT_SMTP_HOST=smtp.example.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=mailbox@example.com
CONTACT_SMTP_PASSWORD=replace-with-smtp-password
CONTACT_TO_EMAIL=contact@example.com
CONTACT_FROM_EMAIL=no-reply@example.com
CONTACT_REPLY_NAME=EMRAN LABS Inquiry
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=900000
