NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only OpenAI Responses API configuration for EM AI.
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=replace-with-responses-api-model-id
AI_RATE_LIMIT_MAX=12
AI_RATE_LIMIT_WINDOW_MS=600000

# Server-only SMTP configuration for the secure Contact application.
CONTACT_SMTP_HOST=smtp.example.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=mailbox@example.com
CONTACT_SMTP_PASSWORD=replace-with-smtp-password
CONTACT_TO_EMAIL=contact@example.com
CONTACT_FROM_EMAIL=no-reply@example.com
CONTACT_REPLY_NAME=EMRAN LABS Inquiry
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=900000

# Optional Search Console/Bing URL-prefix metadata verification fallbacks.
# Prefer Cloudflare DNS TXT verification for Google Search Console Domain properties.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Optional Sentry application error monitoring. Missing DSN disables runtime capture.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0
